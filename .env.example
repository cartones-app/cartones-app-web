# Backend API base URL — Spring Boot.
# Local: http://localhost:9001 (docker-compose)
# Staging: https://backend-staging-de76.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:9001

# ============================================================
# Auth.js (NextAuth v5) — Keycloak OIDC (BFF pattern)
# ============================================================
# Secret para firmar/encriptar el JWT de sesión. Generar con:
#   openssl rand -base64 32
AUTH_SECRET=

# Client ID del client confidential en Keycloak.
AUTH_KEYCLOAK_ID=frontend

# Client secret del client confidential (Keycloak admin → Clients → frontend → Credentials).
AUTH_KEYCLOAK_SECRET=

# URL del realm (issuer del JWT).
# Local: http://localhost:8080/realms/cartones
# Staging: https://keycloak-staging-085a.up.railway.app/realms/cartones
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/cartones

# URL pública de la app (necesario en producción detrás de proxy).
# Vercel lo setea automáticamente vía VERCEL_URL; en local no hace falta.
# AUTH_URL=http://localhost:3000

# Confiar en el host (para deploys detrás de proxy/Vercel).
AUTH_TRUST_HOST=true
