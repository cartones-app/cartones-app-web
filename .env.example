# Backend API base URL — INTERNA, no `NEXT_PUBLIC_*` a propósito.
# El browser nunca la ve: hace todas sus llamadas a `/api-proxy/...`
# (same-origin) y el Next server las forwardea via rewrites a esta URL.
#
# Local dev (Next corriendo en docker con network_mode: host):
#   BACKEND_INTERNAL_URL=http://localhost:9001
# Local dev (Next sin host network, backend en docker network compartida):
#   BACKEND_INTERNAL_URL=http://backend:9001    (DNS interno docker)
# Prod VPS: BACKEND_INTERNAL_URL=http://backend:9001  (mismo, dentro de la
#   network del nginx-proxy — sin necesidad de exponer puerto al exterior).
# Staging Railway: usar la URL pública o privada de Railway según el setup.
BACKEND_INTERNAL_URL=http://localhost:9001

# ============================================================
# Auth.js (NextAuth v5) — Keycloak OIDC (BFF pattern)
# ============================================================
# Secret para firmar/encriptar el JWT de sesión. Generar con:
#   openssl rand -base64 32
AUTH_SECRET=

# Client ID del client confidential en Keycloak.
AUTH_KEYCLOAK_ID=frontend

# Client secret del client confidential (Keycloak admin → Clients → frontend → Credentials).
# DEBE coincidir con `secret` del client `frontend` en infra-keycloak/keycloak/realm-cartones.json.
# Dev local con el realm seed: dev-only-frontend-secret-no-usar-en-prod
AUTH_KEYCLOAK_SECRET=

# URL del realm (issuer del JWT).
# Local: http://localhost:8080/realms/cartones
# Staging: https://keycloak-staging-085a.up.railway.app/realms/cartones
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/cartones

# URL pública de la app (necesario en producción detrás de proxy).
# Vercel lo setea automáticamente vía VERCEL_URL; en local no hace falta.
#
# IMPORTANTE: además de habilitar callbacks de OAuth, NextAuth usa `AUTH_URL`
# (o `Host` con AUTH_TRUST_HOST=true) para validar el `callbackUrl` de signin
# contra open-redirect. Si en prod queda sin setear y `AUTH_TRUST_HOST=false`,
# un atacante podría construir `/login?callbackUrl=https://evil.com` y NextAuth
# podría no rechazar el dominio externo.
# AUTH_URL=http://localhost:3000

# Confiar en el host (para deploys detrás de proxy/Vercel).
# OJO: solo seteá `true` cuando el proxy upstream sanitiza X-Forwarded-Host
# (Vercel lo hace, nginx-proxy en VPS suele también). En proxies custom,
# validar antes — sino abre la puerta a host header injection. En local con
# `npm run dev` no hace falta.
# AUTH_TRUST_HOST=true
