# Copiar a .env.local para correr `pnpm dev` contra el stack local del backend.
#
# Asumiendo que el backend (cartones-app-api) está corriendo con:
#   docker compose up -d
# desde su repo. Eso levanta:
#   - postgres en :${PORT_DB}
#   - keycloak en :${PORT_KEYCLOAK:-8080}  (realm "cartones" pre-importado)
#   - backend en :${PORT_BACKEND}
#
# El realm `cartones` define dos usuarios de prueba (passwords temporary):
#   - admin / admin123                 (rol ADMIN)
#   - distribuidor / distribuidor123   (rol DISTRIBUIDOR)
#
# Client OIDC: "frontend" — publicClient + PKCE (S256). No requiere secret.

# URL pública del backend (se bakea en el bundle al build).
# Ajustar según PORT_BACKEND del .env del backend.
NEXT_PUBLIC_API_URL=http://localhost:9001

# NextAuth runtime.
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=local-dev-secret-do-not-use-in-prod

# Keycloak — usa el client público `frontend` del realm `cartones`
# que ya viene importado por el docker-compose del backend.
AUTH_KEYCLOAK_ID=frontend
# Cliente público (PKCE) → no hay client_secret real, pero NextAuth/oauth4webapi
# requiere que la env exista. Dejá el placeholder.
AUTH_KEYCLOAK_SECRET=public-client
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/cartones
